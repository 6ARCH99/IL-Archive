# Backend API Configuration
# For local development (backend on same machine):
# API_BASE_URL=http://127.0.0.1:3001

# For network access (backend on different machine):
# Replace YOUR_BACKEND_IP with the IP address of the machine running the backend
# Example: API_BASE_URL=http://192.168.1.100:3001
API_BASE_URL=http://127.0.0.1:3001
